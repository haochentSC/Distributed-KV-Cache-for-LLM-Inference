#!/bin/bash
# Cache node bootstrap (Amazon Linux 2023): install Docker, pull the cache image from ECR, and run
# it under systemd via a small wrapper that resolves this instance's id + private IP at start time.
# Templated: region, ecr_registry, ecr_image, etcd_endpoints, cold_bucket, max_bytes, rf, lease_ttl,
# log_group. Terraform fills the templated values above; shell variables are escaped with a doubled
# dollar sign so they survive templating and reach the rendered script literally.
set -euxo pipefail

dnf install -y docker
systemctl enable --now docker

# Authenticate to ECR and pre-pull the image (creds from the instance role — no static keys).
# Non-fatal pull: first boot can race the image push (the ECR repo must exist before the image can
# be pushed), so a missing image must NOT abort user-data — otherwise the unit below never gets
# written and the node can't self-heal. cache-server.service (Restart=always) retries the pull via
# `docker run` until the image lands.
aws ecr get-login-password --region ${region} | docker login --username AWS --password-stdin ${ecr_registry}
docker pull ${ecr_image} || echo "image not present yet; cache-server.service will retry the pull"

# Runtime wrapper: a single-quoted heredoc so the $${...} shell vars stay literal and expand when
# the SERVICE starts (IMDSv2 for the instance id + private advertise IP).
cat >/usr/local/bin/run-cache-server.sh <<'WRAPPER'
#!/bin/bash
set -euo pipefail
TOKEN=$(curl -sX PUT "http://169.254.169.254/latest/api/token" -H "X-aws-ec2-metadata-token-ttl-seconds: 120")
INSTANCE_ID=$(curl -s -H "X-aws-ec2-metadata-token: $${TOKEN}" http://169.254.169.254/latest/meta-data/instance-id)
PRIVATE_IP=$(curl -s -H "X-aws-ec2-metadata-token: $${TOKEN}" http://169.254.169.254/latest/meta-data/local-ipv4)
# AWS_REGION: the SDK inside the container cannot resolve a region on its own (no env, no shared
# config), and an empty region breaks every cold-tier S3 call with "Invalid region" (2026-06-10).
# GOMEMLIMIT keeps the Go GC from letting RSS run to ~2x max-bytes and OOMing a 2 GB t3.small.
exec docker run --rm --name cache-server --network host \
  -e AWS_REGION=${region} \
  -e GOMEMLIMIT=1400MiB \
  --log-driver=awslogs \
  --log-opt awslogs-region=${region} \
  --log-opt awslogs-group=${log_group} \
  --log-opt "awslogs-stream=$${INSTANCE_ID}" \
  ${ecr_image} \
  -addr :50051 \
  -advertise "$${PRIVATE_IP}:50051" \
  -node-id "$${INSTANCE_ID}" \
  -etcd ${etcd_endpoints} \
  -rf ${rf} \
  -lease-ttl ${lease_ttl} \
  -max-bytes ${max_bytes} \
  -metrics-addr :9090 \
  -spot \
  -cold-bucket ${cold_bucket}
WRAPPER
chmod +x /usr/local/bin/run-cache-server.sh

# systemd unit. ExecStop's `docker stop` sends SIGTERM to the container → the deregister-then-drain
# path (ADR 0023); TimeoutStopSec gives the drain room beyond docker's 120s grace.
cat >/etc/systemd/system/cache-server.service <<'UNIT'
[Unit]
Description=kvcache cache-server
After=docker.service network-online.target
Requires=docker.service

[Service]
Restart=always
RestartSec=5
TimeoutStopSec=130
ExecStartPre=-/usr/bin/docker rm -f cache-server
ExecStart=/usr/local/bin/run-cache-server.sh
ExecStop=/usr/bin/docker stop -t 120 cache-server

[Install]
WantedBy=multi-user.target
UNIT

systemctl daemon-reload
systemctl enable --now cache-server
