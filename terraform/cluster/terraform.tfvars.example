# Copy to terraform.tfvars and edit. (terraform.tfvars is gitignored — never commit real values.)

region = "us-east-1"

# REQUIRED: your public IP as a /32. SSH + the metrics port open ONLY to this.
#   curl -s https://checkip.amazonaws.com   ->   203.0.113.4   ->   "203.0.113.4/32"
my_ip_cidr = "203.0.113.4/32"

# Optional: an existing EC2 key pair name for SSH. Leave "" to launch without an SSH key.
key_name = ""

# etcd: 3 = real quorum (recommended, ADR 0009); set 1 for the cheap single-node fallback.
etcd_count = 3

# Cache tier (Spot). Size for RAM; cache_max_bytes ~= 70% of the instance memory.
cache_count         = 3
cache_instance_type = "t3.small"
cache_max_bytes     = 1500000000

# The ECR tag to run. Push it first: scripts/push-image.sh <region> <repo-url> latest
image_tag = "latest"
