# NOTE: .gitignore does NOT support inline (trailing) comments — text after a pattern on the
# same line becomes part of the pattern. Keep every comment on its own line.

# Go
/bin/
*.exe
*.test
*.out
coverage.*
# stray binary from `go build -o loadgen ./cmd/loadgen`
/loadgen

# Real-workload data (large; regenerate with scripts/prep_sharegpt.py — never commit)
sharegpt.json
*.jsonl

# Terraform
**/.terraform/*
# saved terraform plan dumps and plan files (local scratch; may embed sensitive values)
terraform/cluster/plan-*.txt
terraform/cluster/tfplan-*
*.tfstate
*.tfstate.*
# *.tfvars may contain secrets; commit *.tfvars.example instead
*.tfvars
# env-specific backend config; commit backend.hcl.example instead
backend.hcl
crash.log

# Python (vLLM connector)
__pycache__/
*.py[cod]
.venv/
venv/
# pip install -e build metadata
*.egg-info/

# local probe output (the WSL2 reference dump lives under docs/benchmarks/ if committed)
kv_layout_probe.json

# Editor / OS
.DS_Store
.idea/
*.swp

# Local Claude settings (keep shared settings.json, ignore personal overrides)
.claude/settings.local.json
